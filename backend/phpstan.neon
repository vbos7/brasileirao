includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:

    paths:
        - app/

    # Level 10 is the highest level
    level: 6

    # Desativa a verificação de $appends porque o Larastan não reconhece
    # accessors no estilo novo (Attribute::make) para essa regra.
    checkModelAppends: false

#    ignoreErrors:
#        - '#PHPDoc tag @var#'
#
#    excludePaths:
#        - ./*/*/FileToBeExcluded.php
